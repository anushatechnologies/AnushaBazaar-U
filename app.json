{
  "expo": {
    "name": "AnushaBazaar",
    "slug": "AnushaBazaar",
    "scheme": "anushabazaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/company-logo.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/company-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAJpg-ngs-RlNxzeeQGwu9DL6rqWlyYaqg"
        }
      },
      "package": "com.deliveryapp"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Anusha Bazaar to access your location for delivery."
        }
      ]
    ]
  }
}
