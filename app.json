{
  "expo": {
    "name": "AnushaBazaar",
    "slug": "AnushaBazaar",
    "scheme": "anushabazaar",
    "version": "1.0.51",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "versionCode": 51,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "READ_PHONE_STATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyChxzqLaLTuN5cV1LV92yF6tRPh8ZV7FeI"
        }
      },
      "package": "com.anusha.deliveryapp",
      "googleServicesFile": "./google-services.json",
      "queries": [
        {
          "intent": {
            "action": "android.speech.RecognitionService"
          }
        }
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "anushabazaar.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anusha.deliveryapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses microphone for voice search",
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition for voice search",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Anusha Bazaar to access your location for delivery."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow Anusha Bazaar to access your microphone for voice search.",
          "speechRecognitionPermission": "Allow Anusha Bazaar to recognize your speech for voice search."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "dcdcad28-ac38-4705-ac19-d6aa50a5a275"
      }
    },
    "owner": "anushabazaar2"
  }
}
