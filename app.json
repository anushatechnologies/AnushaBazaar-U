{
  "expo": {
    "name": "AnushaBazaar",
    "slug": "AnushaBazaar",
    "scheme": "anushabazaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/company-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/company-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_PHONE_STATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyChxzqLaLTuN5cV1LV92yF6tRPh8ZV7FeI"
        }
      },
      "package": "com.anusha.deliveryapp",
      "enableProguardInReleaseBuilds": true
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Anusha Bazaar to access your location for delivery."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dcdcad28-ac38-4705-ac19-d6aa50a5a275"
      }
    },
    "owner": "anushabazaar2"
  }
}
