{
  "expo": {
    "name": "AnushaBazaar",
    "slug": "AnushaBazaar",
    "scheme": "anushabazaar",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/company-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/company-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "versionCode": 3,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "READ_PHONE_STATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyChxzqLaLTuN5cV1LV92yF6tRPh8ZV7FeI"
        }
      },
      "package": "com.anusha.deliveryapp",
      "googleServicesFile": "./google-services.json",
      "enableProguardInReleaseBuilds": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anusha.deliveryapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses microphone for voice search",
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition for voice search"
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Anusha Bazaar to access your location for delivery."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow Anusha Bazaar to access your microphone for voice search.",
          "speechRecognitionPermission": "Allow Anusha Bazaar to recognize your speech for voice search."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dcdcad28-ac38-4705-ac19-d6aa50a5a275"
      }
    },
    "owner": "anushabazaar2"
  }
}
